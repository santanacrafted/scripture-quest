rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    match /questions/{questionId} {
      allow read: if isAdmin() ||
        (resource.data.status == 'published' && resource.data.isActive == true);
      allow create, update, delete: if isAdmin();

      match /reviews/{reviewId} {
        allow read, write: if isAdmin();
      }
    }

    match /questionReports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.status == 'open';
      allow read, update, delete: if isAdmin();
    }

    match /questionStats/{questionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /questionAuditLogs/{auditId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if false;
    }

    function isMatchParticipant() {
      return signedIn() && request.auth.uid in resource.data.playerIds;
    }

    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId);
      allow update: if isSelf(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'rating',
          'wins',
          'losses',
          'banned',
          'suspended',
          'accountStatus'
        ]);
      allow delete: if false;
    }

    match /friendRequests/{id} {
      allow read: if signedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow write: if false;
    }
    match /friendships/{id} {
      allow read: if signedIn() && request.auth.uid in resource.data.userIds;
      allow write: if false;
    }
    match /blocks/{id} {
      allow read: if signedIn() && resource.data.blockerId == request.auth.uid;
      allow write: if false;
    }
    match /battleInvitations/{id} {
      allow read: if signedIn() && (
        resource.data.recipientId == request.auth.uid
        || resource.data.challengerId == request.auth.uid
      );
      allow write: if false;
    }

    match /matchmakingQueue/{playerId} {
      allow read: if isSelf(playerId);
      allow create, update, delete: if false;
    }

    match /matches/{matchId} {
      allow read: if isMatchParticipant();
      allow create, delete: if false;
      allow update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
