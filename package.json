{
  "name": "scripture-quest",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "prepare:splash": "mkdir -p assets && cp public/app-launch.png assets/splash.png",
    "prepare:ios-splash": "./scripts/prepare-ios-splash.sh",
    "build:mobile": "npm run prepare:splash && npm run build && npx capacitor-assets generate --android --ios && npm run prepare:ios-splash && npx cap sync",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
