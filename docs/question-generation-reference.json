{
  "schemaVersion": "2.1",
  "purpose": "Give this file to ChatGPT when generating Scripture Quest questions. Return only a JSON array of question objects matching the examples.",
  "allowedValues": {
    "language": ["en", "es"],
    "category": ["characters", "scripture", "stories", "places", "bible_knowledge"],
    "questionType": [
      "multiple_choice",
      "pictionary",
      "verse_completion",
      "reference_match",
      "who_am_i",
      "who_said_it",
      "sequence",
      "map_challenge",
      "emoji_challenge",
      "true_false",
      "match_pairs",
      "odd_one_out",
      "what_happens_next",
      "arrange_verse"
    ],
    "difficulty": ["easy", "medium", "hard", "expert"],
    "scope": ["chapter", "book", "multi_book", "whole_bible"],
    "supportedModes": ["quiz", "battle"],
    "testament": ["old", "new"]
  },
  "categoryMeanings": {
    "characters": "People in the Bible",
    "scripture": "Verses, quotations, references, and biblical text",
    "stories": "Events, miracles, parables, and narratives",
    "places": "Geography, journeys, cities, nations, and maps",
    "bible_knowledge": "Books, structure, authorship, themes, and general Bible knowledge"
  },
  "generationRules": [
    "Use only the allowed enum values exactly as written.",
    "Every question needs a unique externalId.",
    "Every question needs a scope. Use chapter when only the cited chapter is needed, book when multiple chapters of one book are needed, multi_book when multiple specific books are needed, and whole_bible for Bible-wide knowledge.",
    "Every question needs a non-empty supportedModes array. Use quiz, battle, or both to control where the question may be served.",
    "Pictionary, map_challenge, and emoji_challenge must use supportedModes [\"battle\"] only.",
    "Every question needs at least one structured passage with canonical bookId and bookName.",
    "chapterEnd must be greater than or equal to chapterStart.",
    "Use answerData.type multiple_choice for multiple_choice, pictionary, verse_completion, who_said_it, emoji_challenge, odd_one_out, and what_happens_next questions.",
    "Those multiple-choice question types require exactly four unique options and exactly one correctOptionId. Players select an option; they do not type an answer.",
    "Pictionary requires media. Replace all placeholder media values with a real uploaded Firebase Storage path and download URL before publishing.",
    "Map challenges require media and a correctRegionId matching an interactive region in the map asset.",
    "Sequence correctPosition values must start at 0 and be consecutive.",
    "Match Pairs requires at least two unique left/right pairs.",
    "Arrange the Verse segment IDs must be unique and correctPosition values must start at 0 and be consecutive.",
    "Use phrase-sized arrange_verse segments for long verses so the game remains playable on mobile.",
    "Distractors must be plausible but unambiguously incorrect.",
    "The explanation must explain the answer instead of merely repeating it.",
    "The scriptureReference must support the answer."
  ],
